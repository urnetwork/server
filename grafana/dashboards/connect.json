{
    "uid": "urnetwork-connect",
    "title": "urnetwork / connect",
    "tags": ["urnetwork"],
    "timezone": "browser",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "templating": {
        "list": [
            {
                "name": "env",
                "label": "env",
                "type": "query",
                "datasource": {"type": "prometheus", "uid": "warp-mimir"},
                "query": "label_values(urnetwork_connect_connected_clients, env)",
                "refresh": 2,
                "sort": 1
            },
            {
                "name": "block",
                "label": "block",
                "type": "query",
                "datasource": {"type": "prometheus", "uid": "warp-mimir"},
                "query": "label_values(urnetwork_connect_connected_clients{env=\"$env\"}, block)",
                "refresh": 2,
                "sort": 1,
                "multi": true,
                "includeAll": true
            },
            {
                "name": "host",
                "label": "host",
                "type": "query",
                "datasource": {"type": "prometheus", "uid": "warp-mimir"},
                "query": "label_values(urnetwork_connect_connected_clients{env=\"$env\"}, host)",
                "refresh": 2,
                "sort": 1,
                "multi": true,
                "includeAll": true
            }
        ]
    },
    "panels": [
        {
            "id": 1,
            "type": "timeseries",
            "title": "connected clients",
            "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
            "datasource": {"type": "prometheus", "uid": "warp-mimir"},
            "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
            "targets": [
                {
                    "refId": "A",
                    "expr": "urnetwork_connect_connected_clients{env=\"$env\",block=~\"$block\",host=~\"$host\"}",
                    "legendFormat": "{{block}} {{host}}"
                },
                {
                    "refId": "B",
                    "expr": "sum(urnetwork_connect_connected_clients{env=\"$env\",block=~\"$block\",host=~\"$host\"})",
                    "legendFormat": "total"
                }
            ]
        },
        {
            "id": 2,
            "type": "timeseries",
            "title": "dropped messages / s",
            "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
            "datasource": {"type": "prometheus", "uid": "warp-mimir"},
            "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum by (host) (rate(urnetwork_connect_forward_dropped_messages{env=\"$env\",block=~\"$block\",host=~\"$host\"}[$__rate_interval]))",
                    "legendFormat": "forward {{host}}"
                },
                {
                    "refId": "B",
                    "expr": "sum by (host) (rate(urnetwork_connect_forward_receive_dropped_messages{env=\"$env\",block=~\"$block\",host=~\"$host\"}[$__rate_interval]))",
                    "legendFormat": "forward receive {{host}}"
                },
                {
                    "refId": "C",
                    "expr": "sum by (host) (rate(urnetwork_connect_abuse_dropped_messages{env=\"$env\",block=~\"$block\",host=~\"$host\"}[$__rate_interval]))",
                    "legendFormat": "abuse {{host}}"
                }
            ]
        }
    ]
}
