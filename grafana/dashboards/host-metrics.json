      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "since last report",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "host": "host"
            }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "time() - max by (host) (timestamp(node_load1{env=\"$env\"}))",
          "datasource": {
            "type": "prometheus",
            "uid": "warp-mimir"
          },
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "100 * (1 - avg by (host)(rate(node_cpu_seconds_total{env=\"$env\",mode=\"idle\"}[$__rate_interval])))",
          "datasource": {
            "type": "prometheus",
            "uid": "warp-mimir"
          },
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "max by (host)(node_load1{env=\"$env\"}) / count by (host)(node_cpu_seconds_total{env=\"$env\",mode=\"idle\"})",
          "datasource": {
            "type": "prometheus",
            "uid": "warp-mimir"
          },
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "100 * (1 - sum by (host)(node_memory_MemAvailable_bytes{env=\"$env\"}) / sum by (host)(node_memory_MemTotal_bytes{env=\"$env\"}))",
          "datasource": {
            "type": "prometheus",
            "uid": "warp-mimir"
          },
          "format": "table",
          "instant": true
        },
        {
          "refId": "E",
          "expr": "100 * (1 - max by (host)(node_filesystem_avail_bytes{env=\"$env\",mountpoint=\"/\"}) / max by (host)(node_filesystem_size_bytes{env=\"$env\",mountpoint=\"/\"}))",
          "datasource": {
            "type": "prometheus",
            "uid": "warp-mimir"
          },
          "format": "table",
          "instant": true
        }
      ]
    },
