{
    "uid": "urnetwork-services",
    "title": "urnetwork / services overview",
    "tags": ["urnetwork"],
    "timezone": "browser",
    "schemaVersion": 39,
    "refresh": "30s",
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "templating": {
        "list": [
            {
                "name": "env",
                "label": "env",
                "type": "query",
                "datasource": {"type": "prometheus", "uid": "warp-mimir"},
                "query": "label_values(go_goroutines, env)",
                "refresh": 2,
                "sort": 1
            },
            {
                "name": "service",
                "label": "service",
                "type": "query",
                "datasource": {"type": "prometheus", "uid": "warp-mimir"},
                "query": "label_values(go_goroutines{env=\"$env\"}, service)",
                "refresh": 2,
                "sort": 1,
                "multi": true,
                "includeAll": true
            },
            {
                "name": "block",
                "label": "block",
                "type": "query",
                "datasource": {"type": "prometheus", "uid": "warp-mimir"},
                "query": "label_values(go_goroutines{env=\"$env\",service=~\"$service\"}, block)",
                "refresh": 2,
                "sort": 1,
                "multi": true,
                "includeAll": true
            },
            {
                "name": "host",
                "label": "host",
                "type": "query",
                "datasource": {"type": "prometheus", "uid": "warp-mimir"},
                "query": "label_values(go_goroutines{env=\"$env\",service=~\"$service\"}, host)",
                "refresh": 2,
                "sort": 1,
                "multi": true,
                "includeAll": true
            }
        ]
    },
    "panels": [
        {
            "id": 1,
            "type": "timeseries",
            "title": "cpu (cores)",
            "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
            "datasource": {"type": "prometheus", "uid": "warp-mimir"},
            "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum by (service, block, host) (rate(process_cpu_seconds_total{env=\"$env\",service=~\"$service\",block=~\"$block\",host=~\"$host\"}[$__rate_interval]))",
                    "legendFormat": "{{service}} {{block}} {{host}}"
                }
            ]
        },
        {
            "id": 2,
            "type": "timeseries",
            "title": "memory (rss)",
            "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
            "datasource": {"type": "prometheus", "uid": "warp-mimir"},
            "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
            "targets": [
                {
                    "refId": "A",
                    "expr": "process_resident_memory_bytes{env=\"$env\",service=~\"$service\",block=~\"$block\",host=~\"$host\"}",
                    "legendFormat": "{{service}} {{block}} {{host}}"
                }
            ]
        },
        {
            "id": 3,
            "type": "timeseries",
            "title": "goroutines",
            "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
            "datasource": {"type": "prometheus", "uid": "warp-mimir"},
            "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
            "targets": [
                {
                    "refId": "A",
                    "expr": "go_goroutines{env=\"$env\",service=~\"$service\",block=~\"$block\",host=~\"$host\"}",
                    "legendFormat": "{{service}} {{block}} {{host}}"
                }
            ]
        },
        {
            "id": 4,
            "type": "timeseries",
            "title": "open file descriptors",
            "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
            "datasource": {"type": "prometheus", "uid": "warp-mimir"},
            "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
            "targets": [
                {
                    "refId": "A",
                    "expr": "process_open_fds{env=\"$env\",service=~\"$service\",block=~\"$block\",host=~\"$host\"}",
                    "legendFormat": "{{service}} {{block}} {{host}}"
                }
            ]
        },
        {
            "id": 5,
            "type": "table",
            "title": "running versions",
            "gridPos": {"h": 7, "w": 24, "x": 0, "y": 16},
            "datasource": {"type": "prometheus", "uid": "warp-mimir"},
            "fieldConfig": {"defaults": {}, "overrides": []},
            "options": {},
            "transformations": [
                {
                    "id": "labelsToFields",
                    "options": {}
                },
                {
                    "id": "organize",
                    "options": {
                        "excludeByName": {
                            "Time": true,
                            "Value": true,
                            "__name__": true,
                            "job": true,
                            "instance": true
                        }
                    }
                }
            ],
            "targets": [
                {
                    "refId": "A",
                    "expr": "urnetwork_build_info{env=\"$env\",service=~\"$service\",block=~\"$block\",host=~\"$host\"}",
                    "format": "table",
                    "instant": true
                }
            ]
        }
    ]
}
