      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "warp-mimir"
          },
          "expr": "sum(rate(urnetwork_connect_transfer_bytes{env=\"$env\"}[$__rate_interval])) * 8",
          "refId": "C",
          "legendFormat": "fleet"
        }
      ],
      "description": "Bytes acked through closed/checkpointed transfer contracts \u2014 the mimir-side proxy for the 1.1 contract-creation rate (the exact per-minute pg rate lives in the monitor). A cliff = systemic; a sag = partial failure; a ramp = recovery."
    },
