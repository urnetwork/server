{
  "uid": "urnetwork-signals",
  "title": "urnetwork / signals",
  "tags": [
    "urnetwork",
    "signals"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "description": "The SIGNALS.md signal catalog, charted. Panel titles carry the section numbers; panel descriptions carry the playbook pointers. Loaded by `bringyourctl grafana load-defaults`.",
  "templating": {
    "list": [
      {
        "name": "env",
        "label": "env",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "warp-mimir"
        },
        "query": "label_values(urnetwork_build_info, env)",
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "tier-0 vitals (SIGNALS.md \u00a71\u20132)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "2.7 new connections / min",
      "datasource": {
        "type": "prometheus",
        "uid": "warp-mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 8,
            "showPoints": "never",
            "stacking": {
              "mode": "none"
            }
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "warp-mimir"
          },
          "expr": "sum(rate(urnetwork_connect_connection_new{env=\"$env\"}[$__rate_interval])) * 60",
          "refId": "A",
          "legendFormat": "fleet"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "warp-mimir"
          },
          "expr": "sum by (host) (rate(urnetwork_connect_connection_new{env=\"$env\"}[$__rate_interval])) * 60",
          "refId": "B",
          "legendFormat": "{{host}}"
        }
      ],
      "description": "The new-connection rate (SIGNALS.md 2.7). Two failure directions: sustained < 50% of the trailing baseline = new connects failing (auth/lb/announce); sustained > 2.5x = a RECONNECT STORM \u2014 mass simultaneous eviction (ansible unit-restart wave 8.5, simultaneous multi-block deploy). During a storm expect a plateau, a final eviction burst spike, then decay to baseline ~10 min after."
    },
    {
      "type": "timeseries",
      "title": "1.1 transfer throughput (contract-path proxy)",
      "datasource": {
        "type": "prometheus",
        "uid": "warp-mimir"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
